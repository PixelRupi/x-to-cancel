{
  "manifest_version": 3,
  "name": "X → XCancel",
  "version": "1.1",
  "permissions": ["tabs", "contextMenus", "scripting", "clipboardWrite", "storage"],
  "host_permissions": ["*://x.com/*", "*://www.x.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}